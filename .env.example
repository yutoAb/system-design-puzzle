# OpenAI API キー（Realtime セッション発行と評価レポート生成に使用）
OPENAI_API_KEY=

# 評価レポートに使うモデル（省略時 gpt-5-mini）
# EVAL_MODEL=gpt-5-mini

# 1 にすると OpenAI を呼ばずスタブ応答を返す（開発用）
# MOCK_OPENAI=1

# 設定すると面接開始・評価APIに招待コードを要求する（公開デプロイ時は必須推奨）
# ACCESS_CODE=

# --- Supabase 認証（未設定ならログイン機能は無効のまま起動する） ---
# クライアント用（Vite がビルド時に埋め込む。公開されて良い値のみ）
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# サーバー用（秘密。VITE_ を付けないこと）
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SECRET_KEY=sb_secret_...

# 1 にすると Supabase を呼ばず固定ユーザーで認証を通す（開発・テスト用）
# MOCK_AUTH=1

# MOCK_AUTH=1 のときの初期チケット残高（省略時 1）
# MOCK_TICKET_BALANCE=1

# --- Stripe（テストモード。未設定なら購入機能は無効のまま） ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...  # 本番: ダッシュボードのエンドポイント設定 / ローカル: stripe listen が表示する値
# STRIPE_PRICE_TICKET_1=price_...  # チケット1枚の Price ID
# STRIPE_PRICE_TICKET_5=price_...  # チケット5枚パックの Price ID

# Checkout の戻り先 URL（本番は https://... を設定）
# APP_BASE_URL=http://localhost:5173

# 1 にすると Stripe を呼ばずスタブ応答を返す（開発・テスト用）
# MOCK_STRIPE=1
